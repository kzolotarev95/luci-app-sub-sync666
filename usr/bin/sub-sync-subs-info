#!/bin/sh
# SUBSYNC_SUBS_INFO_FAST_NO_TIMEOUT_V444
REAL="/usr/bin/sub-sync-subs-info.real-v444"
OUT="/tmp/subsync-subs-info-v444.out.$$"
ERR="/tmp/subsync-subs-info-v444.err.$$"

fallback() {
  printf '[]\n'
}

if [ -x "$REAL" ]; then
  "$REAL" >"$OUT" 2>"$ERR" &
  PID="$!"

  for i in 1 2 3; do
    sleep 1
    if ! kill -0 "$PID" 2>/dev/null; then
      wait "$PID" 2>/dev/null || true
      if [ -s "$OUT" ]; then cat "$OUT"; else fallback; fi
      rm -f "$OUT" "$ERR"
      exit 0
    fi
  done

  kill "$PID" 2>/dev/null || true
  wait "$PID" 2>/dev/null || true
fi

fallback
rm -f "$OUT" "$ERR"
exit 0
