#!/bin/sh
# SUBSYNC_FAST_DASH_DELETE_ALIASES_V444_BEGIN
case "${1:-}" in
  subs-info) exec /usr/bin/sub-sync-subs-info ;;
  dashboard-v403) [ -x /usr/bin/sub-sync-dashboard-v403 ] && exec /usr/bin/sub-sync-dashboard-v403 ;;
  dashboard-ping-v403) shift; [ -x /usr/bin/sub-sync-dashboard-ping-v403 ] && exec /usr/bin/sub-sync-dashboard-ping-v403 "$@" ;;
  stage-delete-active) shift; [ -x /usr/bin/sub-sync-delete-server ] && exec /usr/bin/sub-sync-delete-server stage-active "$@" ;;
  apply-delete-active) [ -x /usr/bin/sub-sync-delete-server ] && exec /usr/bin/sub-sync-delete-server apply-staged ;;
  delete-server-active) shift; [ -x /usr/bin/sub-sync-delete-server ] && exec /usr/bin/sub-sync-delete-server delete-active "$@" ;;
esac
# SUBSYNC_FAST_DASH_DELETE_ALIASES_V444_END
# SUBSYNC_HY2_MANUAL_ADD_WRAPPER_V436B
case "${1:-}" in
  hy2-manual-add|manual-hy2-add)
    shift
    exec /usr/bin/sub-sync-hy2-manual-v436b add "$@"
  ;;
esac
# SUBSYNC_SOURCE_MAP_WRAPPER_V432C
case "${1:-}" in
  sync)
    shift
    /usr/bin/sub-sync.real sync "$@"
    _rc="$?"
    /usr/bin/sub-sync-link-source-map-v432c >/tmp/subsync-v432c-map.log 2>&1 || true
    [ -x /usr/bin/sub-sync-happ-json-hy2-import ] && /usr/bin/sub-sync-happ-json-hy2-import >/tmp/subsync-hy2-import-last-v436c.log 2>&1 || true # SUBSYNC_HY2_IMPORT_LAST_AFTER_SYNC_V436C
    /usr/bin/sub-sync-hy2-manual-v436b merge >/tmp/subsync-hy2-manual-v436b.log 2>&1 || true # SUBSYNC_HY2_MANUAL_MERGE_AFTER_SYNC_V436B
    exit "$_rc"
  ;;
  del-sub|delete-sub|remove-sub|delete-subscription)
    shift
    exec /usr/bin/sub-sync-del-sub-source-clean-v432c "$@"
  ;;
esac
# SUBSYNC_STAGED_DELETE_ALIAS_V427B
case "${1:-}" in
  stage-delete-active) shift; exec /usr/bin/sub-sync-delete-server stage-active "$@" ;;
  apply-delete-active) shift; exec /usr/bin/sub-sync-delete-server apply-staged "$@" ;;
esac
# SUBSYNC_WRAPPER_HAPP_HY2_DELETE_EMPTY_V221
# includes SUBSYNC_WRAPPER_HAPP_HY2_DELETE_EMPTY_V220
# includes SUBSYNC_WRAPPER_EMPTY_SUBS_EMPTY_SERVERS_V219
# includes SUBSYNC_WRAPPER_DELETE_REBUILD_CACHE_V218
# includes SUBSYNC_WRAPPER_SUBS_INFO_ALIAS_V213

REAL="/usr/bin/sub-sync.real"
# SUBSYNC_DELETE_SUB_PURGE_ACTIVE_SECTIONS_V331_WRAPPER
case "${1:-}" in
  # SUBSYNC_DELETE_SERVER_ACTIVE_WRAPPER_V403K
  delete-server-active)
    shift
    exec /usr/bin/sub-sync-delete-server delete-active "$@"
  ;;
  # SUBSYNC_DELETE_SERVER_LINK_WRAPPER_V403J
  delete-server-link)
    shift
    exec /usr/bin/sub-sync-delete-server delete-link "$@"
  ;;
  # SUBSYNC_DASHBOARD_PING_WRAPPER_V403D
  dashboard-ping-v403)
    shift
    exec /usr/bin/sub-sync-dashboard-ping-v403 "$@"
  ;;
  # SUBSYNC_DASHBOARD_ACTIVE_WRAPPER_V403
  dashboard-v403)
    shift
    exec /usr/bin/sub-sync-dashboard-v403 "$@"
  ;;
  # SUBSYNC_DELETE_SERVER_WRAPPER_V403
  delete-server|del-server|remove-server)
    shift
    exec /usr/bin/sub-sync-delete-server delete "$@"
  ;;
  servers)
    [ -x /usr/bin/sub-sync-delete-server ] && /usr/bin/sub-sync-delete-server apply >/dev/null 2>&1 || true
    exec "$REAL" servers
  ;;
  txt-v348) shift; exec /usr/bin/sub-sync-txt-v348 "$@" ;; # SUBSYNC_TXT_BLOCK_V348_WRAPPER
  txt-v346) shift; exec /usr/bin/sub-sync-txt-v346 "$@" ;; # SUBSYNC_TXT_BLOCK_V346_WRAPPER
  txt-v345) shift; exec /usr/bin/sub-sync-txt-v345 "$@" ;; # SUBSYNC_TXT_BLOCK_V345_WRAPPER
  delete-purge-v331)
    shift
    exec /usr/bin/sub-sync-delete-purge-active-v331 "$@"
  ;;
  del-sub|delete-sub|remove-sub|delete-subscription)
    _cmd="$1"
    shift
    _rc=0
    "$REAL" "$_cmd" "$@" || _rc="$?"
    /usr/bin/sub-sync-delete-purge-active-v331 2>&1 || true
    exit "$_rc"
  ;;
esac
HY2="/usr/bin/sub-sync-happ-json-hy2-import"

if [ ! -x "$REAL" ]; then
  echo "ERROR: /usr/bin/sub-sync.real not found"
  exit 1
fi

empty_if_no_subs() {
  mkdir -p /etc/sub-sync
  subs="$("$REAL" list-subs 2>/dev/null || echo "[]")"

  if printf '%s' "$subs" | grep -q '^\[\]$'; then
    echo '[]' > /etc/sub-sync/servers.json
    : > /etc/sub-sync/links.txt
    echo "Нет подписок — servers.json очищен"
    return 0
  fi

  return 1
}

rebuild_servers_cache() {
  mkdir -p /etc/sub-sync

  if empty_if_no_subs; then
    return 0
  fi

  rm -f /etc/sub-sync/servers.json /etc/sub-sync/links.txt 2>/dev/null || true

  "$REAL" sync 2>&1
  rc="$?"

  if [ "$rc" = "0" ] && [ -x "$HY2" ]; then
    "$HY2" 2>&1 || true
  fi

  if [ ! -s /etc/sub-sync/servers.json ]; then
    echo '[]' > /etc/sub-sync/servers.json
  fi

  # SUBSYNC_AUTOLOGIC_AFTER_SYNC_HOOK_V398P
  if [ "$rc" = "0" ] && [ -x /usr/bin/sub-sync-autoadd ]; then
    /usr/bin/sub-sync-autoadd autologic-run 2>&1 || true
  fi
  # SUBSYNC_DELETE_SERVER_APPLY_BLACKLIST_V403
  [ -x /usr/bin/sub-sync-delete-server ] && /usr/bin/sub-sync-delete-server apply >/dev/null 2>&1 || true
  return "$rc"
}

case "${1:-}" in
  subs-info)
    if [ -x /usr/bin/sub-sync-subs-info ]; then
      exec /usr/bin/sub-sync-subs-info
    fi
  ;;

  system-info)
    if [ -x /usr/bin/sub-sync-system-info ]; then
      exec /usr/bin/sub-sync-system-info
    fi
  ;;

  singbox-log)
    shift
    if [ -x /usr/bin/sub-sync-singbox-log ]; then
      exec /usr/bin/sub-sync-singbox-log "$@"
    fi
  ;;

  sync|update|refresh)
    rebuild_servers_cache
    exit "$?"
  ;;

  add-sub|delete-sub|del-sub|remove-sub|delete-subscription)
    "$REAL" "$@"
    rc="$?"
    rebuild_servers_cache || true
    exit "$rc"
  ;;
esac

exec "$REAL" "$@"
