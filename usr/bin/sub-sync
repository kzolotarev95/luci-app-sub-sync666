#!/bin/sh
# SUBSYNC_HAPP_JSON_HY2_WRAPPER_V177
BASE="/usr/bin/sub-sync.before-happ-json-hy2-v177"
HELPER="/usr/bin/sub-sync-happ-json-hy2-import"

case "${1:-}" in
  sync|update|refresh)
    "$BASE" "$@"
    rc="$?"
    if [ "$rc" = "0" ] && [ -x "$HELPER" ]; then
      "$HELPER" || true
    fi
    exit "$rc"
  ;;
  *)
    exec "$BASE" "$@"
  ;;
esac
