#!/bin/sh
# SUBSYNC_HY2_UI_PING_V168J_BEGIN
set -u

PREV="/usr/bin/sub-sync-manual-import.v168j-prev"
CFG="/etc/sing-box/config.json"

cmd="${1:-list-hy2}"

get_controller() {
  if command -v jq >/dev/null 2>&1; then
    jq -r '.experimental.clash_api.external_controller // empty' "$CFG" 2>/dev/null | head -n 1
  else
    sed -n 's/.*"external_controller"[ ]*:[ ]*"\([^"]*\)".*/\1/p' "$CFG" | head -n 1
  fi
}

get_tags() {
  if command -v jq >/dev/null 2>&1; then
    jq -r '
      .outbounds[]?
      | select(
          ((.tag // "") | startswith("zkssss324234")) and
          ((.type == "hysteria2") or (.type == "urltest") or (.type == "selector"))
        )
      | .tag
    ' "$CFG" 2>/dev/null
  else
    grep '"tag": "zkssss324234' "$CFG" | sed 's/.*"tag": "\([^"]*\)".*/\1/'
  fi
}

ping_hy2() {
  ctrl="$(get_controller)"

  if [ -z "$ctrl" ]; then
    echo "ERROR: clash_api external_controller not found"
    exit 2
  fi

  case "$ctrl" in
    http://*|https://*) base="$ctrl" ;;
    *) base="http://$ctrl" ;;
  esac

  enc_url="https%3A%2F%2Fwww.gstatic.com%2Fgenerate_204"

  echo "CTRL=$ctrl"

  best_delay=""
  best_tag=""

  get_tags | while read -r tag; do
    [ -n "$tag" ] || continue

    out="$(
      wget -T 10 -qO- "$base/proxies/$tag/delay?timeout=8000&url=$enc_url" 2>/tmp/subsync-hy2-v168j-wget.err || true
    )"

    delay="$(printf '%s' "$out" | sed -n 's/.*"delay"[ ]*:[ ]*\([0-9][0-9]*\).*/\1/p' | head -n 1)"

    if [ -n "$delay" ]; then
      echo "$tag=$delay"
    else
      echo "$tag=ERR"
      [ -s /tmp/subsync-hy2-v168j-wget.err ] && sed 's/^/ERRMSG=/' /tmp/subsync-hy2-v168j-wget.err
    fi
  done
}

case "$cmd" in
  ping-hy2|hy2-ping|ping)
    ping_hy2
    ;;
  *)
    exec "$PREV" "$@"
    ;;
esac
# SUBSYNC_HY2_UI_PING_V168J_END
