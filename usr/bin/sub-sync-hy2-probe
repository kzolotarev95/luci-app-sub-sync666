#!/bin/sh
# SUBSYNC_HY2_WORK_PROBE_V180
set -u

LINK="${1:-}"
TEST_URL="${2:-https://www.gstatic.com/generate_204}"

mask() {
  sed -E 's#(hy2|hysteria2)://[^@[:space:]]+@#\1://***@#g'
}

fail() {
  echo "NO WORK: $*"
  exit 1
}

[ -n "$LINK" ] || fail "HY2 link empty"

LINK="$(printf '%s' "$LINK" | sed 's/[[:space:]]*$//;s/#.*$//')"

case "$LINK" in
  hy2://*|hysteria2://*) ;;
  *) fail "only hy2:// or hysteria2:// supported" ;;
esac

REST="${LINK#*://}"
AUTH="${REST%%@*}"
HPQ="${REST#*@}"

[ "$AUTH" != "$REST" ] || fail "missing password/auth before @"

HOSTPORT="${HPQ%%/*}"
HOST="${HOSTPORT%:*}"
PORT="${HOSTPORT##*:}"

[ -n "$HOST" ] || fail "host empty"
case "$PORT" in
  ''|*[!0-9]*) fail "bad port: $PORT" ;;
esac

SNI="$(printf '%s' "$HPQ" | sed -n 's/.*[?&]sni=\([^&#]*\).*/\1/p' | head -1)"
[ -n "$SNI" ] || SNI="$HOST"

TMP="/tmp/subsync-hy2-probe.$$"
mkdir -p "$TMP"
CFG="$TMP/config.json"
LOG="$TMP/sing-box.log"
ERR="$TMP/curl.err"
PORT_LOCAL=$((18080 + ($$ % 1000)))

cleanup() {
  [ -n "${PID:-}" ] && kill "$PID" 2>/dev/null || true
  rm -rf "$TMP"
}
trap cleanup EXIT INT TERM

echo "HY2 probe v180"
echo "Link: $(printf '%s' "$LINK" | mask)"
echo "Server: $HOST:$PORT"
echo "SNI: $SNI"
echo "Test URL: $TEST_URL"
echo

command -v sing-box >/dev/null 2>&1 || fail "sing-box not found"

jq -n \
  --arg listen "127.0.0.1" \
  --argjson lport "$PORT_LOCAL" \
  --arg server "$HOST" \
  --argjson sport "$PORT" \
  --arg password "$AUTH" \
  --arg sni "$SNI" \
  '{
    log: { level: "error", timestamp: false },
    inbounds: [
      { type: "mixed", tag: "mixed-in", listen: $listen, listen_port: $lport }
    ],
    outbounds: [
      {
        type: "hysteria2",
        tag: "hy2-out",
        server: $server,
        server_port: $sport,
        password: $password,
        tls: { enabled: true, server_name: $sni }
      },
      { type: "direct", tag: "direct" }
    ],
    route: {
      rules: [
        { inbound: ["mixed-in"], outbound: "hy2-out" }
      ],
      final: "hy2-out"
    }
  }' > "$CFG" || fail "cannot create temp sing-box config"

echo "=== sing-box config check ==="
if ! sing-box check -c "$CFG" > "$TMP/check.out" 2>&1; then
  cat "$TMP/check.out"
  fail "temporary sing-box config invalid"
fi
cat "$TMP/check.out"
echo "OK: temp config valid"
echo

echo "=== start temp sing-box ==="
sing-box run -c "$CFG" > "$LOG" 2>&1 &
PID="$!"
sleep 2

if ! kill -0 "$PID" 2>/dev/null; then
  echo "--- sing-box log ---"
  cat "$LOG"
  fail "temp sing-box stopped"
fi

echo "OK: temp sing-box running on socks/mixed 127.0.0.1:$PORT_LOCAL"
echo

if ! command -v curl >/dev/null 2>&1; then
  echo "WARN: curl not found"
  echo "CONFIG OK, but real HTTP test skipped"
  exit 0
fi

echo "=== HTTP test through HY2 ==="
OUT="$(curl -k -sS --max-time 12 --connect-timeout 6 \
  --proxy "socks5h://127.0.0.1:$PORT_LOCAL" \
  -o /dev/null -w '%{http_code} %{time_total}' \
  "$TEST_URL" 2>"$ERR" || true)"

CODE="$(printf '%s' "$OUT" | awk '{print $1}')"
TIME="$(printf '%s' "$OUT" | awk '{print $2}')"

if [ "$CODE" = "204" ] || [ "$CODE" = "200" ] || [ "$CODE" = "301" ] || [ "$CODE" = "302" ]; then
  echo "WORK: HTTP $CODE, time ${TIME}s"
  exit 0
fi

echo "--- curl error ---"
cat "$ERR" 2>/dev/null || true
echo "--- sing-box log ---"
cat "$LOG" 2>/dev/null || true
fail "HTTP test failed, code=${CODE:-none}"
