#!/bin/sh
# PODCOP_SUB_V666_PERSISTENT_GUARD_V274
LOGTAG="podcop-sub-v666-guard"
changed=0

if [ -f /usr/share/luci/menu.d/luci-app-sub-sync.json ]; then
  rm -f /usr/share/luci/menu.d/luci-app-sub-sync.json 2>/dev/null || true
  rm -rf /tmp/luci-modulecache /tmp/luci-modulecache/* /tmp/luci-indexcache /tmp/luci-indexcache* 2>/dev/null || true
  logger -t "$LOGTAG" "removed duplicate standalone Подписки / Мониторинг menu"
  changed=1
fi

if [ -x /usr/bin/podcop-sub-v666-xhttp-patch ]; then
  if ! grep -q 'xhttp|http)' /usr/lib/podkop/sing_box_config_facade.sh 2>/dev/null || \
     ! grep -q 'sing_box_cm_set_xhttp_transport' /usr/lib/podkop/sing_box_config_manager.sh 2>/dev/null; then
    logger -t "$LOGTAG" "xHTTP patch missing, repairing"
    /usr/bin/podcop-sub-v666-xhttp-patch >/tmp/podcop-sub-v666-xhttp-patch.log 2>&1 || logger -t "$LOGTAG" "xHTTP repair failed"
    changed=1
  fi
fi

[ "$changed" = "0" ] && logger -t "$LOGTAG" "OK"
exit 0
