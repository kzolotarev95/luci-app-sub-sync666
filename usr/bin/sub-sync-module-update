#!/bin/sh
# SUBSYNC_MODULE_UPDATE_HELPER_V261
set -u

RAW_BASE="${SUBSYNC_RAW_BASE:-https://raw.githubusercontent.com/kzolotarev95/luci-app-sub-sync666/main}"
VERSION_URL="$RAW_BASE/version.json?v=$(date +%s)"
LOCAL_BUILD_FILE="/etc/sub-sync/module-build"
LOCAL_VERSION_FILE="/etc/sub-sync/module-version"

json_get() {
  sed -n 's/.*"'$1'"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$2" | head -n1
}

json_get_num() {
  sed -n 's/.*"'$1'"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p' "$2" | head -n1
}

local_build() {
  cat "$LOCAL_BUILD_FILE" 2>/dev/null | tr -dc '0-9' | head -c 10
}

local_version() {
  cat "$LOCAL_VERSION_FILE" 2>/dev/null | head -n1
}

download_version() {
  tmp="$1"
  wget -qO "$tmp" "$VERSION_URL"
}

cmd_check() {
  vf="/tmp/subsync-version-check-$$.json"
  lb="$(local_build)"
  lv="$(local_version)"
  [ -n "$lb" ] || lb=0
  [ -n "$lv" ] || lv="unknown"

  echo "=== Podcop Sub v666 update check v261 ==="

  if ! download_version "$vf"; then
    echo "STATUS=ERROR"
    echo "CURRENT_VERSION=$lv"
    echo "CURRENT_BUILD=$lb"
    echo "ERROR: Не удалось скачать version.json"
    rm -f "$vf"
    exit 1
  fi

  rv="$(json_get version "$vf")"
  rb="$(json_get_num build "$vf")"
  title="$(json_get title "$vf")"
  msg="$(json_get message "$vf")"

  [ -n "$rv" ] || rv="unknown"
  [ -n "$rb" ] || rb=0

  echo "LOCAL_VERSION=$lv"
  echo "LOCAL_BUILD=$lb"
  echo "REMOTE_VERSION=$rv"
  echo "REMOTE_BUILD=$rb"
  echo "TITLE=$title"
  echo "MESSAGE=$msg"

  if [ "$rb" -gt "$lb" ]; then
    echo "STATUS=UPDATE_AVAILABLE"
    echo "UPDATE_AVAILABLE"
    echo "Текущая версия: $lv ($lb)"
    echo "Последняя версия: $rv ($rb)"
    echo "Доступно обновление до $rv. Можно нажать «Обновить модуль»."
  else
    echo "STATUS=UP_TO_DATE"
    echo "UP_TO_DATE"
    echo "Текущая версия: $lv ($lb)"
    echo "Последняя версия: $rv ($rb)"
    echo "У вас последняя версия $rv. Обновление не требуется."
  fi

  rm -f "$vf"
}

cmd_update() {
  start="$(date +%s)"
  vf="/tmp/subsync-version-update-$$.json"
  inst="/tmp/subsync-install-update-$$.sh"

  lb="$(local_build)"
  lv="$(local_version)"
  [ -n "$lb" ] || lb=0
  [ -n "$lv" ] || lv="unknown"

  echo "=== Podcop Sub v666 update v261 ==="
  echo "[00:00] Старт обновления"
  echo "[00:00] Текущая версия: $lv ($lb)"

  echo "[00:00] [1/7] Скачиваю version.json"
  if ! download_version "$vf"; then
    echo "ERROR: Не удалось скачать version.json"
    rm -f "$vf" "$inst"
    exit 1
  fi

  rv="$(json_get version "$vf")"
  rb="$(json_get_num build "$vf")"
  marker="$(json_get required_marker "$vf")"
  url="$(json_get install_url "$vf")"

  [ -n "$rb" ] || rb=0
  [ -n "$rv" ] || rv="unknown"
  [ -n "$url" ] || url="$RAW_BASE/install.sh"

  echo "[00:00] Последняя версия: $rv ($rb)"

  if [ "$rb" -le "$lb" ]; then
    echo "UP_TO_DATE"
    echo "У вас последняя версия $rv. Обновление не требуется."
    rm -f "$vf" "$inst"
    exit 0
  fi

  echo "[00:00] [2/7] Скачиваю install.sh"
  if ! wget -qO "$inst" "$url?v=$(date +%s)"; then
    echo "ERROR: Не удалось скачать install.sh"
    rm -f "$vf" "$inst"
    exit 1
  fi

  echo "[00:00] [3/7] Проверяю защитный marker"
  if [ -n "$marker" ] && ! grep -q "$marker" "$inst"; then
    echo "SAFE_STOP"
    echo "Обновление остановлено защитой: marker не найден: $marker"
    rm -f "$vf" "$inst"
    exit 2
  fi

  echo "[00:00] [4/7] Проверяю синтаксис install.sh"
  if ! sh -n "$inst"; then
    echo "ERROR: install.sh не прошёл sh -n"
    rm -f "$vf" "$inst"
    exit 3
  fi

  echo "[00:00] [5/7] Запускаю установку $rv"
  sh "$inst"
  rc="$?"

  now="$(date +%s)"
  elapsed="$((now - start))"

  echo "[$elapsed сек] [6/7] install.sh завершился rc=$rc"

  if [ "$rc" -ne 0 ]; then
    echo "ERROR: установка завершилась с ошибкой rc=$rc"
    rm -f "$vf" "$inst"
    exit "$rc"
  fi

  echo "[$elapsed сек] [7/7] Готово"
  echo "DONE: install.sh finished rc=0"
  echo "DONE: Podcop Sub v666 $rv installed. LuCI will restart in a few seconds."

  rm -f "$vf" "$inst"
}

case "${1:-check}" in
  check) cmd_check ;;
  update) cmd_update ;;
  *) echo "Usage: $0 check|update"; exit 1 ;;
esac
