#!/bin/sh
# SUBSYNC_STAGED_DELETE_HELPER_V427B

LINK="${2:-}"
ID="${3:-}"
SEC="${4:-}"
CODE="${5:-}"
ADDR="${6:-}"
PORT="${7:-}"
NAME="${8:-}"
SERVERS="/etc/sub-sync/servers.json"
LINKS="/etc/sub-sync/links.txt"

json_ok() { echo '{"status":"ok"}'; }
json_err() { printf '{"status":"error","message":"%s"}\n' "$1"; }

remove_from_list() {
  sec="$1"; opt="$2"; link="$3"
  vals="$(uci -q get podkop.$sec.$opt 2>/dev/null || true)"
  [ -n "$vals" ] || return 0

  keep=""
  removed=0
  for v in $vals; do
    if [ -n "$link" ] && [ "$v" = "$link" ]; then
      removed=1
      continue
    fi
    keep="$keep
$v"
  done

  [ "$removed" = "1" ] || return 0

  uci -q delete podkop.$sec.$opt 2>/dev/null || true
  n=0
  printf '%s\n' "$keep" | sed '/^$/d' | while IFS= read -r v; do
    n=$((n+1))
    if [ "$opt" = "proxy_string" ] && [ "$n" = "1" ]; then
      uci -q set podkop.$sec.$opt="$v"
    else
      uci -q add_list podkop.$sec.$opt="$v"
    fi
  done

  left="$(uci -q get podkop.$sec.$opt 2>/dev/null || true)"
  [ -n "$left" ] || uci -q delete podkop.$sec 2>/dev/null || true
}

stage_active() {
  link="$1"; id="$2"; sec="$3"; code="$4"; addr="$5"; port="$6"; name="$7"

  if [ -n "$sec" ] && uci -q get podkop.$sec >/dev/null 2>&1; then
    typ="$(uci -q get podkop.$sec.proxy_config_type 2>/dev/null || true)"
    case "$typ" in
      outbound)
        uci -q delete podkop.$sec 2>/dev/null || true
      ;;
      urltest)
        remove_from_list "$sec" "urltest_proxy_links" "$link"
      ;;
      selector)
        remove_from_list "$sec" "selector_proxy_links" "$link"
      ;;
      url|"")
        remove_from_list "$sec" "proxy_string" "$link"
      ;;
    esac
  fi

  for s in $(uci show podkop 2>/dev/null | sed -n "s/^podkop\.\([^.=]*\)=.*/\1/p" | sort -u); do
    [ -n "$link" ] && {
      remove_from_list "$s" "proxy_string" "$link"
      remove_from_list "$s" "urltest_proxy_links" "$link"
      remove_from_list "$s" "selector_proxy_links" "$link"
    }
  done

  if [ -s "$LINKS" ] && [ -n "$link" ]; then
    grep -Fvx "$link" "$LINKS" > "$LINKS.tmp.$$" || true
    mv "$LINKS.tmp.$$" "$LINKS"
  fi

  if [ -s "$SERVERS" ]; then
    jq --arg link "$link" --arg sec "$sec" --arg code "$code" --arg addr "$addr" --arg port "$port" '
      map(select(
        (($link != "" and ((.link // "") == $link)) or
         ($sec != "" and $code != "" and ((.section // "") == $sec) and ((.code // "") == $code)) or
         ($addr != "" and ((.addr // "") == $addr) and (((.port // "")|tostring) == ($port|tostring))))
        | not
      ))
    ' "$SERVERS" > "$SERVERS.tmp.$$" 2>/dev/null && mv "$SERVERS.tmp.$$" "$SERVERS" || rm -f "$SERVERS.tmp.$$"
  fi

  json_ok
}

apply_staged() {
  uci commit podkop 2>/dev/null || true
  /etc/init.d/podkop restart >/tmp/subsync-delete-podkop-restart.log 2>&1 || true
  json_ok
}

case "${1:-}" in
  stage-active) shift; stage_active "${1:-}" "${2:-}" "${3:-}" "${4:-}" "${5:-}" "${6:-}" "${7:-}" ;;
  apply-staged) shift; apply_staged ;;
  delete-active) shift; stage_active "${1:-}" "${2:-}" "${3:-}" "${4:-}" "${5:-}" "${6:-}" "${7:-}"; apply_staged ;;
  delete-link) shift; stage_active "${1:-}" "" "" "" "" "" ""; apply_staged ;;
  *) json_err "usage: stage-active|apply-staged|delete-active" ;;
esac
