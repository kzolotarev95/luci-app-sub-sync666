#!/bin/sh
# SUBSYNC_DELETE_TARGET_SECTION_V51

BASE="/usr/bin/sub-sync.v51base"
AUTO_CONF="/etc/sub-sync/autoadd.conf"
DATA="/etc/sub-sync"
LINKS="$DATA/links.txt"
SERVERS="$DATA/servers.json"

if [ "${1:-}" != "del-sub" ]; then
    exec "$BASE" "$@"
fi

target_section() {
    T="$(sed -n 's/^TARGET_SECTION=//p' "$AUTO_CONF" 2>/dev/null | tail -n 1)"
    [ -n "$T" ] || T="TEST123"
    echo "$T"
}

add_unique_file() {
    F="$1"
    sort -u "$F" -o "$F" 2>/dev/null || true
}

collect_remaining_subsync_links() {
    OUT="$1"
    : > "$OUT"

    [ -f "$LINKS" ] && sed '/^[[:space:]]*$/d' "$LINKS" >> "$OUT" || true

    if [ -f "$SERVERS" ]; then
        grep -o '"url":"[^"]*"' "$SERVERS" 2>/dev/null | sed 's/^"url":"//;s/"$//;s#\\/#/#g' >> "$OUT" || true
        grep -o '"link":"[^"]*"' "$SERVERS" 2>/dev/null | sed 's/^"link":"//;s/"$//;s#\\/#/#g' >> "$OUT" || true
    fi

    add_unique_file "$OUT"
}

collect_target_links() {
    SEC="$1"
    OUT="$2"
    : > "$OUT"

    [ -n "$SEC" ] || return 0
    uci -q show "podkop.${SEC}" >/dev/null 2>&1 || return 0

    uci -q get "podkop.${SEC}.urltest_proxy_links" 2>/dev/null | tr ' ' '\n' | sed '/^[[:space:]]*$/d' >> "$OUT" || true
    uci -q get "podkop.${SEC}.selector_proxy_links" 2>/dev/null | tr ' ' '\n' | sed '/^[[:space:]]*$/d' >> "$OUT" || true

    P="$(uci -q get "podkop.${SEC}.proxy_string" 2>/dev/null || true)"
    [ -n "$P" ] && echo "$P" >> "$OUT"

    add_unique_file "$OUT"
}

target_has_links() {
    SEC="$1"
    A="$(uci -q get "podkop.${SEC}.urltest_proxy_links" 2>/dev/null || true)"
    B="$(uci -q get "podkop.${SEC}.selector_proxy_links" 2>/dev/null || true)"
    C="$(uci -q get "podkop.${SEC}.proxy_string" 2>/dev/null || true)"
    [ -n "$A$B$C" ]
}

remove_link_from_target() {
    SEC="$1"
    P="$2"

    [ -n "$SEC" ] || return 0
    [ -n "$P" ] || return 0
    uci -q show "podkop.${SEC}" >/dev/null 2>&1 || return 0

    uci -q del_list "podkop.${SEC}.urltest_proxy_links=${P}" 2>/dev/null && echo 1 > "$CHANGED" || true
    uci -q del_list "podkop.${SEC}.selector_proxy_links=${P}" 2>/dev/null && echo 1 > "$CHANGED" || true

    CUR="$(uci -q get "podkop.${SEC}.proxy_string" 2>/dev/null || true)"
    if [ "$CUR" = "$P" ]; then
        uci -q delete "podkop.${SEC}.proxy_string" 2>/dev/null || true
        echo 1 > "$CHANGED"
    fi
}

T="$(target_section)"
OLD="/tmp/subsync-v51-old.$$"
NEW="/tmp/subsync-v51-new.$$"
CHANGED="/tmp/subsync-v51-changed.$$"

: > "$OLD"
: > "$NEW"
: > "$CHANGED"

collect_target_links "$T" "$OLD"

OUT="$("$BASE" "$@" 2>&1)"
RC="$?"
printf '%s\n' "$OUT"

if [ "$RC" != "0" ]; then
    rm -f "$OLD" "$NEW" "$CHANGED"
    exit "$RC"
fi

"$BASE" sync >/tmp/sub-sync-delete-v51-resync.log 2>&1 || true
collect_remaining_subsync_links "$NEW"

while IFS= read -r P; do
    [ -n "$P" ] || continue

    if ! grep -Fxq "$P" "$NEW" 2>/dev/null; then
        remove_link_from_target "$T" "$P"
    fi
done < "$OLD"

if uci -q show "podkop.${T}" >/dev/null 2>&1; then
    if ! target_has_links "$T"; then
        uci -q delete "podkop.${T}" 2>/dev/null || true
        echo 1 > "$CHANGED"
        DELETED=1
    else
        DELETED=0
    fi
else
    DELETED=0
fi

if [ -s "$CHANGED" ]; then
    uci commit podkop 2>/dev/null || true
    /etc/init.d/podkop restart 2>/dev/null || true
    DID=1
else
    DID=0
fi

logger -t sub-sync "delete target section v51: target=${T} changed=${DID} deleted=${DELETED:-0}"
echo "OK: target cleaned: ${T}"

rm -f "$OLD" "$NEW" "$CHANGED"
exit 0
