#!/bin/sh

N="${1:-160}"

case "$N" in
    ''|*[!0-9]*) N=160 ;;
esac

[ "$N" -lt 20 ] && N=20
[ "$N" -gt 300 ] && N=300

echo "=== Sing-box / Podkop realtime log: $(date '+%Y-%m-%d %H:%M:%S') ==="
echo "=== tail: $N, refresh: LuCI panel ==="
echo ""

logread 2>/dev/null | grep -Ei \
'sing-box|singbox|podkop:.*sing-box|podkop:.*outbound|podkop:.*inbound|podkop:.*route|podkop:.*DNS|podkop:.*config|podkop:.*Nice|configuration .* invalid|jq: invalid|fatal|failed|error|invalid' \
| tail -n "$N" || true
