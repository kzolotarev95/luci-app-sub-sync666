#!/bin/sh
# SUBSYNC_SUB_INFO_HELPER_MANUAL_EXPIRE_V25

REAL="/usr/bin/sub-sync.real"
META="/etc/sub-sync/subs-meta.tsv"
MANUAL="/etc/sub-sync/subs-manual.tsv"

mkdir -p /etc/sub-sync
touch "$META" "$MANUAL" 2>/dev/null || true

json_escape() {
    printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\r//g' | tr '\n' ' '
}

num_or_zero() {
    v="$1"
    case "$v" in
        ''|*[!0-9]*) echo 0 ;;
        *) echo "$v" ;;
    esac
}

decode_title() {
    t="$1"
    case "$t" in
        base64:*)
            raw="${t#base64:}"
            dec="$(printf '%s' "$raw" | base64 -d 2>/dev/null || true)"
            [ -n "$dec" ] && printf '%s' "$dec" || printf '%s' "$t"
            ;;
        *) printf '%s' "$t" ;;
    esac
}

date_text() {
    e="$1"
    [ -n "$e" ] || e=0
    [ "$e" = "0" ] && { echo "нет данных"; return; }
    date -d "@$e" '+%d.%m.%Y %H:%M:%S' 2>/dev/null || echo "$e"
}

list_urls() {
    json="/tmp/subsync-subs-list-$$.json"
    out="/tmp/subsync-subs-urls-$$.txt"
    out2="/tmp/subsync-subs-urls2-$$.txt"

    rm -f "$json" "$out" "$out2"
    "$REAL" list-subs > "$json" 2>/dev/null || true

    jsonfilter -i "$json" -e '@[*].url' > "$out" 2>/dev/null || true

    if ! grep -q '^https\?://' "$out" 2>/dev/null; then
        jsonfilter -i "$json" -e '@[*]' > "$out" 2>/dev/null || true
    fi

    if ! grep -q '^https\?://' "$out" 2>/dev/null; then
        tr '{' '\n' < "$json" | sed -n 's/.*"url"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' > "$out" 2>/dev/null || true
    fi

    awk '
        {
            u = $0
            gsub(/^[ \t"]+/, "", u)
            gsub(/[ \t"]+$/, "", u)
            gsub(/\\\//, "/", u)
            gsub(/\\"/, "\"", u)
            if (u ~ /^https?:\/\// && !seen[u]++) print u
        }
    ' "$out" > "$out2"

    cat "$out2"
    rm -f "$json" "$out" "$out2"
}

resolve_url() {
    target="$1"
    case "$target" in
        http://*|https://*) echo "$target"; return ;;
    esac

    case "$target" in
        ''|*[!0-9]*) return 1 ;;
    esac

    list_urls | awk -v n="$target" 'NR == n { print; exit }'
}

get_first_seen() {
    url="$1"
    old="$(awk -v u="$url" 'BEGIN{FS="\t"} $1 == u { print $2; exit }' "$META" 2>/dev/null || true)"
    if [ -n "$old" ]; then
        echo "$old"
        return
    fi

    now="$(date +%s)"
    printf '%s\t%s\n' "$url" "$now" >> "$META" 2>/dev/null || true
    echo "$now"
}

manual_get_expire() {
    url="$1"
    awk -v u="$url" 'BEGIN{FS="\t"} $1 == u { print $2; exit }' "$MANUAL" 2>/dev/null || true
}

manual_set_expire() {
    target="$1"
    spec="$2"

    url="$(resolve_url "$target" || true)"
    if [ -z "$url" ]; then
        echo "ERROR: subscription not found: $target"
        exit 1
    fi

    now="$(date +%s)"

    case "$spec" in
        *d)
            days="${spec%d}"
            case "$days" in ''|*[!0-9]*) echo "ERROR: bad days: $spec"; exit 1 ;; esac
            expire=$((now + days * 86400))
            ;;
        *[!0-9]*|'')
            echo "ERROR: use days like 20d or epoch seconds"
            exit 1
            ;;
        *)
            if [ "$spec" -lt 1000000000 ] 2>/dev/null; then
                expire=$((now + spec * 86400))
            else
                expire="$spec"
            fi
            ;;
    esac

    tmp="/tmp/subsync-manual-$$.tsv"
    awk -v u="$url" 'BEGIN{FS=OFS="\t"} $1 != u { print }' "$MANUAL" 2>/dev/null > "$tmp" || true
    printf '%s\t%s\n' "$url" "$expire" >> "$tmp"
    mv "$tmp" "$MANUAL"

    echo "OK: manual expire set"
    echo "URL: $url"
    echo "EXPIRE: $expire"
    echo "DATE: $(date_text "$expire")"
}

manual_clear_expire() {
    target="$1"
    url="$(resolve_url "$target" || true)"
    if [ -z "$url" ]; then
        echo "ERROR: subscription not found: $target"
        exit 1
    fi

    tmp="/tmp/subsync-manual-clear-$$.tsv"
    awk -v u="$url" 'BEGIN{FS=OFS="\t"} $1 != u { print }' "$MANUAL" 2>/dev/null > "$tmp" || true
    mv "$tmp" "$MANUAL"

    echo "OK: manual expire cleared"
    echo "URL: $url"
}

header_value_from_file() {
    key="$1"
    file="$2"

    awk -v k="$key" '
        {
            low = tolower($0)
            kk = tolower(k) ":"
            if (index(low, kk) > 0) {
                sub(/^[^:]*:[ \t]*/, "", $0)
                gsub(/\r/, "", $0)
                val = $0
            }
        }
        END { print val }
    ' "$file" 2>/dev/null
}

kv_from_userinfo() {
    key="$1"
    ui="$2"

    printf '%s\n' "$ui" |
    tr ';' '\n' |
    awk -F '=' -v k="$key" '
        {
            gsub(/^[ \t]+|[ \t]+$/, "", $1)
            gsub(/^[ \t]+|[ \t]+$/, "", $2)
            if ($1 == k) {
                print $2
                exit
            }
        }
    '
}

fetch_fast() {
    url="$1"
    hdr="$2"
    body="$3"

    rm -f "$hdr" "$body"
    : > "$hdr"
    : > "$body"

    curl -sk -L \
        -D "$hdr" \
        -o "$body" \
        -H 'User-Agent: v2rayN/6.42' \
        --connect-timeout 5 \
        --max-time 10 \
        "$url" >/tmp/subsync-fast-v25.out 2>/tmp/subsync-fast-v25.err || true
}

gb() {
    awk -v b="$1" 'BEGIN { if (b <= 0) print "0 GB"; else printf "%.2f GB", b/1024/1024/1024 }'
}

debug_one() {
    wanted="${1:-1}"
    url="$(resolve_url "$wanted" || true)"

    if [ -z "$url" ]; then
        echo "ERROR: subscription not found: $wanted"
        exit 1
    fi

    hdr="/tmp/subsync-debug-v25-hdr.txt"
    body="/tmp/subsync-debug-v25-body.txt"

    fetch_fast "$url" "$hdr" "$body"

    echo "URL: $url"
    echo "=== HEADERS ==="
    grep -Ei 'HTTP/|subscription-userinfo:|profile-title:|profile-update-interval:|support-url:|content-type:|content-length:|location:' "$hdr" || head -n 80 "$hdr"

    ui="$(header_value_from_file 'subscription-userinfo' "$hdr")"
    if [ -n "$ui" ]; then
        up="$(num_or_zero "$(kv_from_userinfo upload "$ui")")"
        down="$(num_or_zero "$(kv_from_userinfo download "$ui")")"
        total="$(num_or_zero "$(kv_from_userinfo total "$ui")")"
        exp_raw="$(num_or_zero "$(kv_from_userinfo expire "$ui")")"
        exp_manual="$(num_or_zero "$(manual_get_expire "$url")")"

        exp="$exp_raw"
        source="provider"
        if [ "$exp" = "0" ] && [ "$exp_manual" != "0" ]; then
            exp="$exp_manual"
            source="manual"
        fi

        used=$((up + down))
        left=$((total - used))
        [ "$left" -lt 0 ] && left=0

        echo "=== PARSED ==="
        echo "upload=$up / $(gb "$up")"
        echo "download=$down / $(gb "$down")"
        echo "used=$used / $(gb "$used")"
        echo "total=$total / $(gb "$total")"
        echo "left=$left / $(gb "$left")"
        echo "expire_raw=$exp_raw / $(date_text "$exp_raw")"
        echo "expire_final=$exp / $(date_text "$exp")"
        echo "expire_source=$source"
    else
        echo "NO subscription-userinfo header"
    fi
}

case "${1:-}" in
    debug)
        shift
        debug_one "${1:-1}"
        exit 0
        ;;
    set-expire)
        manual_set_expire "${2:-}" "${3:-}"
        exit 0
        ;;
    clear-expire)
        manual_clear_expire "${2:-}"
        exit 0
        ;;
    manual-list)
        cat "$MANUAL"
        exit 0
        ;;
esac

now="$(date +%s)"

echo '{'
echo '"checked_at":'"$now"','
echo '"subscriptions":['

first=1
idx=0

list_urls | while IFS= read -r url; do
    [ -n "$url" ] || continue

    idx=$((idx + 1))
    first_seen="$(get_first_seen "$url")"

    hdr="/tmp/subsync-v25-info-hdr-$$-$idx.txt"
    body="/tmp/subsync-v25-info-body-$$-$idx.txt"

    fetch_fast "$url" "$hdr" "$body"

    userinfo="$(header_value_from_file 'subscription-userinfo' "$hdr")"
    profile_title_raw="$(header_value_from_file 'profile-title' "$hdr")"
    profile_title="$(decode_title "$profile_title_raw")"
    profile_update="$(header_value_from_file 'profile-update-interval' "$hdr")"
    support_url="$(header_value_from_file 'support-url' "$hdr")"
    http_code="$(awk 'tolower($0) ~ /^http\// { c=$2 } END { print c }' "$hdr" 2>/dev/null)"
    body_size="$(wc -c < "$body" 2>/dev/null || echo 0)"

    upload="$(num_or_zero "$(kv_from_userinfo upload "$userinfo")")"
    download="$(num_or_zero "$(kv_from_userinfo download "$userinfo")")"
    total="$(num_or_zero "$(kv_from_userinfo total "$userinfo")")"
    expire_raw="$(num_or_zero "$(kv_from_userinfo expire "$userinfo")")"
    expire_manual="$(num_or_zero "$(manual_get_expire "$url")")"

    expire="$expire_raw"
    expire_source="provider"
    if [ "$expire" = "0" ]; then
        expire_source=""
        if [ "$expire_manual" != "0" ]; then
            expire="$expire_manual"
            expire_source="manual"
        fi
    fi

    status="ok"
    [ -z "$userinfo" ] && status="no_userinfo"

    if [ "$first" = 1 ]; then
        first=0
    else
        printf ',\n'
    fi

    printf '{'
    printf '"index":%s,' "$idx"
    printf '"url":"%s",' "$(json_escape "$url")"
    printf '"probe_url":"%s",' "$(json_escape "$url")"
    printf '"title":"%s",' "$(json_escape "$profile_title")"
    printf '"status":"%s",' "$(json_escape "$status")"
    printf '"first_seen":%s,' "$(num_or_zero "$first_seen")"
    printf '"checked_at":%s,' "$now"
    printf '"upload":%s,' "$upload"
    printf '"download":%s,' "$download"
    printf '"total":%s,' "$total"
    printf '"expire":%s,' "$expire"
    printf '"expire_raw":%s,' "$expire_raw"
    printf '"expire_manual":%s,' "$expire_manual"
    printf '"expire_source":"%s",' "$(json_escape "$expire_source")"
    printf '"profile_update_interval":"%s",' "$(json_escape "$profile_update")"
    printf '"support_url":"%s",' "$(json_escape "$support_url")"
    printf '"user_agent":"v2rayN/6.42",'
    printf '"http_code":"%s",' "$(json_escape "$http_code")"
    printf '"body_size":%s' "$(num_or_zero "$body_size")"
    printf '}'

    rm -f "$hdr" "$body"
done

echo ''
echo ']'
echo '}'
